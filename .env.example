# ============================================================================
# Variables de entorno — Elia Pastelería (Fase 2)
# Copiar a .env.local para desarrollo y cargar las mismas en Vercel (Settings →
# Environment Variables). NUNCA commitear .env.local con valores reales.
# ============================================================================

# --- Supabase ---------------------------------------------------------------
# Supabase → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Service role: SOLO en el servidor (API routes). No exponer al cliente.
SUPABASE_SERVICE_ROLE_KEY=

# --- Resend (emails de confirmación) ----------------------------------------
# Resend → API Keys
RESEND_API_KEY=
# Remitente verificado en Resend (mientras no haya dominio: onboarding@resend.dev)
ORDER_FROM_EMAIL=onboarding@resend.dev
# Casilla donde la pastelera recibe los pedidos
ORDER_NOTIFY_EMAIL=
